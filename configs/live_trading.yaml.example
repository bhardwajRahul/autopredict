# Inactive Live-Mode Safety Fixture
# INACTIVE REFERENCE ONLY: supported live commands are hard-disabled.
# This file is retained for offline safety-audit tests. It cannot enable orders,
# must not be copied into an operational config, and does not justify provisioning
# venue credentials.
#
# This deliberately contains no credentials or production instructions.

name: inactive_live_safety_fixture
description: Inactive live-mode reference for offline safety tests

strategy:
  name: conservative_live
  min_edge: 0.08                    # Reference value only; execution is disabled
  kelly_fraction: 0.20              # More conservative Kelly fraction
  max_position_pct: 0.01            # Max 1% of bankroll per position
  aggressive_edge: 0.15             # Higher threshold for market orders
  min_book_liquidity: 100.0         # Require deeper liquidity
  max_spread_pct: 0.03              # Tighter spread tolerance
  max_depth_fraction: 0.10          # Take less depth to minimize impact
  split_threshold_fraction: 0.20    # Split more aggressively
  limit_price_improvement_ticks: 2.0  # More aggressive limit pricing

risk:
  max_position_per_market: 50.0     # Offline validation value
  max_total_exposure: 200.0         # Offline validation value
  max_daily_loss: 25.0              # Offline validation value
  kill_switch_threshold: -50.0      # Offline validation value
  max_positions: 10                 # Fewer simultaneous positions
  max_correlation_exposure: 0.2     # Lower correlation exposure
  position_timeout_hours: 72.0      # Close positions after 3 days
  enable_kill_switch: true          # Required by offline safety validation

venue:
  name: polymarket
  mode: live                        # Test input only; entrypoints fail closed
  api_key: null                     # Deliberately inert
  api_secret: null                  # Deliberately inert
  base_url: null                    # Use default URL
  max_requests_per_minute: 30       # Conservative rate limiting
  timeout_seconds: 30.0
  enable_websocket: false           # No live transport in this fixture
  testnet: true                     # Inert validation value

backtest:
  initial_bankroll: 1000.0          # Test value only
  commission_rate: 0.01             # Test value only
  slippage_model: market_impact
  slippage_bps: 10.0
  start_date: null
  end_date: null
  data_source: none                 # No runtime data source

logging:
  log_dir: ./logs/inactive-live-fixture
  log_level: INFO
  log_trades: true
  log_decisions: true
  log_performance: true
  performance_interval_minutes: 15.0
  structured_format: true
  console_output: true

metadata:
  created: "2026-03-26"
  purpose: "Inactive live-mode safety-audit fixture"
  tags:
    - live
    - disabled
    - offline-test
